# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Base Network (Blockchain) ────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
WALLET_PRIVATE_KEY=0x...
LOAN_CONTRACT_ADDRESS=0x...

# ── LangGraph / OpenAI ───────────────────────────────────
OPENAI_API_KEY=sk-...

# ── MCP Transport ────────────────────────────────────────
# "stdio" for local/testing, "sse" for HTTP/SSE deployment
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
