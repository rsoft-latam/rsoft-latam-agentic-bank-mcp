# ── Environment ──────────────────────────────────────────────

# === AWS ===
AWS_PROFILE=........
AWS_REGION=.......
AWS_ACCOUNT_ID=.........
ECR_REPO=agentic-ai/rsoft-agentic-bank-moltbook
LOCAL_IMAGE=rsoft-agentic-bank-moltbook

# "local" loads .env file, "prod" expects AWS env vars
ENV=local

# ── RSoft Agentic Bank Backend ──────────────────────────────
BACKEND_URL=https://5q765f54g24stjmejrwcoacfay0xcoak.lambda-url.us-east-1.on.aws/api/v1

# ── MCP Transport ────────────────────────────────────────────
# "stdio" for local/testing, "streamable-http" for Lambda/production
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── x402 Payments (wallet that receives USDC) ──────────────
BANK_WALLET_ADDRESS=0xYourBankWalletAddress
X402_NETWORK_ID=base-sepolia

# ── App Settings ─────────────────────────────────────────────
LOG_LEVEL=INFO
